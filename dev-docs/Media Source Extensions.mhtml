>"
              to "<a data-link-type=3D"idl" href=3D"https://w3c.github.io/m=
edia-source/#dom-readystate-open" class=3D"internalDFN" id=3D"ref-for-dom-r=
eadystate-open-8"><code>open</code></a>" or from "<a data-link-type=3D"idl"=
 href=3D"https://w3c.github.io/media-source/#dom-readystate-ended" class=3D=
"internalDFN" id=3D"ref-for-dom-readystate-ended-2"><code>ended</code></a>"=
 to "<a data-link-type=3D"idl" href=3D"https://w3c.github.io/media-source/#=
dom-readystate-open" class=3D"internalDFN" id=3D"ref-for-dom-readystate-ope=
n-9"><code>open</code></a>".
            </td>
          </tr>
          <tr>
            <td>
              <dfn class=3D"event" data-dfn-type=3D"event" id=3D"dfn-source=
ended" tabindex=3D"0" aria-haspopup=3D"dialog" data-export=3D"">sourceended=
</dfn>
            </td>
            <td>
              <a data-link-type=3D"interface" data-lt=3D"Event" href=3D"htt=
ps://dom.spec.whatwg.org/#event"><code>Event</code></a>
            </td>
            <td>
              <a data-link-type=3D"idl" data-lt=3D"MediaSource" href=3D"htt=
ps://w3c.github.io/media-source/#dom-mediasource" class=3D"internalDFN" id=
=3D"ref-for-dom-mediasource-39"><code>MediaSource</code></a>'s <a data-link=
-type=3D"idl" href=3D"https://w3c.github.io/media-source/#dom-mediasource-r=
eadystate" class=3D"internalDFN" id=3D"ref-for-dom-mediasource-readystate-1=
4"><code>readyState</code></a> transitions from "<a data-link-type=3D"idl" =
href=3D"https://w3c.github.io/media-source/#dom-readystate-open" class=3D"i=
nternalDFN" id=3D"ref-for-dom-readystate-open-10"><code>open</code></a>"
              to "<a data-link-type=3D"idl" href=3D"https://w3c.github.io/m=
edia-source/#dom-readystate-ended" class=3D"internalDFN" id=3D"ref-for-dom-=
