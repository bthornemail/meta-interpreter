ttr">min:</span> <span class=3D"hljs-number">50</span>}},
        {<span class=3D"hljs-attr">frameRate:</span> {<span class=3D"hljs-a=
ttr">min:</span> <span class=3D"hljs-number">40</span>}}
      ]
    }
  }<span class=3D"hljs-string">);</span>
