"><span class=3D"hljs-string">try</span> {
  <span class=3D"hljs-string">const</span> <span class=3D"hljs-string">stre=
am</span> <span class=3D"hljs-string">=3D</span> <span class=3D"hljs-string=
">await</span> <span class=3D"hljs-string">navigator.mediaDevices.getUserMe=
dia(</span>{
    <span class=3D"hljs-attr">video:</span> {
      <span class=3D"hljs-attr">width:</span> {<span class=3D"hljs-attr">mi=
n:</span> <span class=3D"hljs-number">640</span>, <span class=3D"hljs-attr"=
>ideal:</span> <span class=3D"hljs-number">1280</span>},
      <span class=3D"hljs-attr">height:</span> {<span class=3D"hljs-attr">m=
