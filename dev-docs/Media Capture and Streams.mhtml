attribute" data-link-type=3D"attribute" data-link-for=3D"MediaStreamTrack" =
data-xref-for=3D"MediaStreamTrack" data-lt=3D"[[ReadyState]]" href=3D"https=
://w3c.github.io/mediacapture-main/#dfn-readystate" class=3D"internalDFN" i=
