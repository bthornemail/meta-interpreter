        {<span class=3D"hljs-attr">width:</span> <span class=3D"hljs-number=
">1920</span>, <span class=3D"hljs-attr">height:</span> <span class=3D"hljs=
-number">1280</span>},
        {<span class=3D"hljs-attr">aspectRatio:</span> <span class=3D"hljs-=
