H2v1h5V7zm2 3V8l-3 3 3 3v-2h5v-2H9zM4.5 9H2v1h2.5V9zM2 12h2.5v-1H2v1zm9 1h1=
v2c-.02.28-.11.52-.3.7-.19.18-.42.28-.7.3H1c-.55 0-1-.45-1-1V4c0-.55.45-1 1=
-1h3c0-1.11.89-2 2-2 1.11 0 2 .89 2 2h3c.55 0 1 .45 1 1v5h-1V6H1v9h10v-2zM2=
 5h8c0-.55-.45-1-1-1H8c-.55 0-1-.45-1-1s-.45-1-1-1-1 .45-1 1-.45 1-1 1H3c-.=
55 0-1 .45-1 1z"></path></svg></button></span><code><span data-idl=3D"" cla=
ss=3D"idlDictionary" id=3D"idl-def-constraintset" data-title=3D"ConstraintS=
et">dictionary <a class=3D"internalDFN idlID" data-link-for=3D"" data-link-=
type=3D"dictionary" href=3D"https://w3c.github.io/mediacapture-main/#dom-co=
nstraintset" id=3D"ref-for-dom-constraintset-3"><code>ConstraintSet<!---0.0=
32930%--></code></a> {};<!---0.032930%--></span><!---0.032930%--></code></p=
re>
      </div>
      <p>Each member of a <dfn data-export=3D"" data-dfn-type=3D"dictionary=
" id=3D"dom-constraintset" data-idl=3D"dictionary" data-title=3D"Constraint=
Set" data-dfn-for=3D"" tabindex=3D"0" aria-haspopup=3D"dialog"><code>Constr=
aintSet</code></dfn> corresponds to a
      constrainable property and specifies a subset of the property's valid
      Capability values. Applying a ConstraintSet instructs the <a data-lin=
k-type=3D"dfn|abstract-op" href=3D"https://w3c.github.io/mediacapture-main/=
#dfn-user-agent" class=3D"internalDFN" id=3D"ref-for-dfn-user-agent-137">Us=
er Agent<!---0.032930%--></a> to
      restrict the settings of the corresponding constrainable properties t=
o
      the specified values or ranges of values. A given property <em class=
=3D"rfc2119">MAY<!---0.032930%--></em> occur both
      in the basic Constraints set and in the advanced ConstraintSets list,=
 and
      <em class=3D"rfc2119">MAY<!---0.032930%--></em> occur at most once in=
 each ConstraintSet in the advanced list.</p>
      <div class=3D"example">Template:
        <pre class=3D"idl def" id=3D"webidl-26239275"><span class=3D"idlHea=
der"><a class=3D"self-link" href=3D"https://w3c.github.io/mediacapture-main=
/#webidl-26239275">WebIDL</a><button title=3D"Copy IDL to clipboard" class=
=3D"respec-button-copy-paste removeOnSave"><svg height=3D"16" viewBox=3D"0 =
0 14 16" width=3D"14"><path fill-rule=3D"evenodd" d=3D"M2 13h4v1H2v-1zm5-6H=
2v1h5V7zm2 3V8l-3 3 3 3v-2h5v-2H9zM4.5 9H2v1h2.5V9zM2 12h2.5v-1H2v1zm9 1h1v=
2c-.02.28-.11.52-.3.7-.19.18-.42.28-.7.3H1c-.55 0-1-.45-1-1V4c0-.55.45-1 1-=
1h3c0-1.11.89-2 2-2 1.11 0 2 .89 2 2h3c.55 0 1 .45 1 1v5h-1V6H1v9h10v-2zM2 =
5h8c0-.55-.45-1-1-1H8c-.55 0-1-.45-1-1s-.45-1-1-1-1 .45-1 1-.45 1-1 1H3c-.5=
5 0-1 .45-1 1z"></path></svg></button></span><code><span data-idl=3D"" clas=
s=3D"idlDictionary" id=3D"idl-def-constraints" data-title=3D"Constraints">d=
ictionary <a class=3D"internalDFN idlID" data-link-for=3D"" data-link-type=
=3D"dictionary" href=3D"https://w3c.github.io/mediacapture-main/#dom-constr=
aints" id=3D"ref-for-dom-constraints-10"><code>Constraints<!---0.032930%-->=
</code></a> : <span class=3D"idlSuperclass"><a data-link-type=3D"idl" data-=
xref-type=3D"_IDL_" href=3D"https://w3c.github.io/mediacapture-main/#dom-co=
nstraintset" class=3D"internalDFN" id=3D"ref-for-dom-constraintset-4"><code=
>ConstraintSet<!---0.032930%--></code></a><!---0.032930%--></span> {<span d=
ata-idl=3D"" class=3D"idlMember" id=3D"idl-def-constraints-advanced" data-t=
itle=3D"advanced" data-dfn-for=3D"Constraints"><span class=3D"idlType">
  <a data-xref-type=3D"dfn" data-cite=3D"webidl" data-cite-path=3D"" data-c=
ite-frag=3D"idl-sequence" data-link-type=3D"dfn" href=3D"https://webidl.spe=
c.whatwg.org/#idl-sequence">sequence<!---0.032930%--></a>&lt;<a data-link-t=
ype=3D"idl" data-xref-type=3D"_IDL_" href=3D"https://w3c.github.io/mediacap=
ture-main/#dom-constraintset" class=3D"internalDFN" id=3D"ref-for-dom-const=
raintset-5"><code>ConstraintSet<!---0.032930%--></code></a>&gt;<!---0.03293=
