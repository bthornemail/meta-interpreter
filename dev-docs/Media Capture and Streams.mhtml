--0.032930%-->
  </div><!---0.032930%--> <pre aria-busy=3D"false"><code class=3D"hljs css"=
>{
  frameRate: <span class=3D"hljs-number">30.0</span>,
  facingMode: <span class=3D"hljs-string">'user'</span>
}</code></pre><!---0.032930%-->
