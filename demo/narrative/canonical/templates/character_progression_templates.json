{
  "type": "character_progression_template_bundle",
  "version": 1,
  "description": "Reusable story progression diagrams encoded as canonical semantic artifact templates.",
  "templates": [
    {
      "id": "tpl_watcher_bootstrap_loop_v1",
      "name": "Watcher Bootstrap Loop",
      "kind": "semantic_graph_artifact_template",
      "summary": "Boot -> alignment -> chapter traversal -> hub return.",
      "nodes": [
        { "id": "n_watcher", "label": "Watcher", "kind": "role" },
        { "id": "n_boot", "label": "Bootstrap", "kind": "event" },
        { "id": "n_hub", "label": "Hub", "kind": "place" },
        { "id": "n_chapter", "label": "Chapter", "kind": "place" },
        { "id": "n_artifact", "label": "Artifact", "kind": "artifact" }
      ],
      "edges": [
        { "id": "e1", "subject": "n_watcher", "predicate": "enters", "object": "n_boot" },
        { "id": "e2", "subject": "n_boot", "predicate": "reveals", "object": "n_hub" },
        { "id": "e3", "subject": "n_watcher", "predicate": "enters", "object": "n_chapter" },
        { "id": "e4", "subject": "n_chapter", "predicate": "grants", "object": "n_artifact" },
        { "id": "e5", "subject": "n_artifact", "predicate": "unlocks", "object": "n_hub" }
      ],
      "transitions": [
        { "id": "t1", "op": "add_edge", "target_id": "e1" },
        { "id": "t2", "op": "add_edge", "target_id": "e2" },
        { "id": "t3", "op": "add_edge", "target_id": "e3" },
        { "id": "t4", "op": "add_edge", "target_id": "e4" },
        { "id": "t5", "op": "add_edge", "target_id": "e5" }
      ]
    },
